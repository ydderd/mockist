{
  "name": "mockist",
  "version": "0.1.0",
  "description": "Stub the tool calls your agent makes through the Vercel AI SDK — return canned values or errors, then assert the recorded call trajectory.",
  "license": "Elastic-2.0",
  "author": "Dhanvi Reddy",
  "homepage": "https://github.com/ydderd/mockist#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ydderd/mockist.git"
  },
  "bugs": {
    "url": "https://github.com/ydderd/mockist/issues"
  },
  "keywords": [
    "ai",
    "vercel-ai-sdk",
    "agent",
    "tools",
    "tool-calling",
    "testing",
    "mock",
    "stub",
    "trajectory",
    "llm"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./vitest-setup": {
      "import": {
        "types": "./dist/setup/vitest.d.ts",
        "default": "./dist/setup/vitest.js"
      },
      "require": {
        "types": "./dist/setup/vitest.d.cts",
        "default": "./dist/setup/vitest.cjs"
      }
    },
    "./jest-setup": {
      "import": {
        "types": "./dist/setup/jest.d.ts",
        "default": "./dist/setup/jest.js"
      },
      "require": {
        "types": "./dist/setup/jest.d.cts",
        "default": "./dist/setup/jest.cjs"
      }
    },
    "./vitest-matchers": {
      "import": {
        "types": "./dist/matchers/vitest.d.ts",
        "default": "./dist/matchers/vitest.js"
      },
      "require": {
        "types": "./dist/matchers/vitest.d.cts",
        "default": "./dist/matchers/vitest.cjs"
      }
    },
    "./jest-matchers": {
      "import": {
        "types": "./dist/matchers/jest.d.ts",
        "default": "./dist/matchers/jest.js"
      },
      "require": {
        "types": "./dist/matchers/jest.d.cts",
        "default": "./dist/matchers/jest.cjs"
      }
    }
  },
  "bin": {
    "mockist": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "publish:public": "npm publish --access public"
  },
  "engines": {
    "node": ">=22"
  },
  "peerDependencies": {
    "ai": "^6.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "@types/node": "^25.9.2",
    "ai": "^6.0.197",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "zod": "^4.4.3"
  }
}
