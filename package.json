{
  "name": "mockist",
  "version": "0.1.0",
  "description": "Stub the tool calls your agent makes through the Vercel AI SDK — return canned values or errors, then assert the recorded call trajectory.",
  "license": "Elastic-2.0",
  "author": "Dhanvi Reddy",
  "homepage": "https://github.com/ydderd/mockist#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ydderd/mockist.git"
  },
  "bugs": {
    "url": "https://github.com/ydderd/mockist/issues"
  },
  "keywords": [
    "ai",
    "vercel-ai-sdk",
    "agent",
    "tools",
    "tool-calling",
    "testing",
    "mock",
    "stub",
    "trajectory",
    "llm"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vitest-setup": {
      "types": "./dist/setup/vitest.d.ts",
      "import": "./dist/setup/vitest.js"
    },
    "./jest-setup": {
      "types": "./dist/setup/jest.d.ts",
      "import": "./dist/setup/jest.js"
    }
  },
  "bin": {
    "mockist": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:jest": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:all": "npm run test && npm run test:jest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "ai": "^6.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.2",
    "ai": "^6.0.197",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "zod": "^4.4.3"
  }
}
